{
  "name": "context-packer",
  "displayName": "Context Packer",
  "description": "Pack selected files into structured Markdown for AI context. Token-aware.",
  "version": "1.0.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "keywords": ["ai", "context", "tokens", "clipboard", "markdown"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "contextPacker.packSelected",
        "title": "Context Packer: Pack Selected Files",
        "icon": "$(clippy)"
      },
      {
        "command": "contextPacker.showPanel",
        "title": "Context Packer: Open Panel"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "contextPacker.packSelected",
          "group": "navigation@99",
          "when": "explorerViewletVisible"
        }
      ]
    },
    "configuration": {
      "title": "Context Packer",
      "properties": {
        "contextPacker.tokenModel": {
          "type": "string",
          "default": "cl100k",
          "enum": ["cl100k", "o200k", "gpt2"],
          "enumDescriptions": [
            "GPT-4 / Claude (cl100k_base) — ~4 chars/token",
            "GPT-4o / o1 (o200k_base) — ~4.2 chars/token",
            "GPT-2 / legacy — ~3.5 chars/token"
          ],
          "description": "Token estimation model"
        },
        "contextPacker.maxFileSize": {
          "type": "number",
          "default": 500,
          "description": "Max file size in KB to include (larger files are skipped)"
        },
        "contextPacker.excludePatterns": {
          "type": "array",
          "default": ["*.lock", "*.min.js", "*.map", "node_modules/**"],
          "description": "Glob patterns to exclude from packing"
        },
        "contextPacker.includeTree": {
          "type": "boolean",
          "default": true,
          "description": "Include file tree at the top of the output"
        },
        "contextPacker.wrapInXml": {
          "type": "boolean",
          "default": false,
          "description": "Wrap each file in <file> XML tags instead of Markdown fences"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "contextPacker",
          "title": "Context Packer",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "contextPacker": [
        {
          "id": "contextPackerPanel",
          "name": "Pack & Stats",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
